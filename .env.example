DJANGO_SECRET_KEY=replace-this-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database Configuration (Neon PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host.neon.tech:5432/dbname
# Optional: set to true only when you want local development to use Neon instead of SQLite
DJANGO_USE_REMOTE_DB=false

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

GEMINI_DEFAULT_MODEL=gemini-2.5-flash
TERMINAL_TIMEOUT_SECONDS=5
